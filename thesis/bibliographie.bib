  title = {Single-Cell Reconstruction of the Early Maternal–Fetal Interface in Humans},
  author = {Vento-Tormo, Roser and Efremova, Mirjana and Botting, Rachel A. and Turco, Margherita Y. and Vento-Tormo, Miquel and Meyer, Kerstin B. and Park, Jong-Eun and Stephenson, Emily and Polański, Krzysztof and Goncalves, Angela and Gardner, Lucy and Holmqvist, Staffan and Henriksson, Johan and Zou, Angela and Sharkey, Andrew M. and Millar, Ben and Innes, Barbara and Wood, Laura and Wilbrey-Clark, Anna and Payne, Rebecca P. and Ivarsson, Martin A. and Lisgo, Steve and Filby, Andrew and Rowitch, David H. and Bulmer, Judith N. and Wright, Gavin J. and Stubbington, Michael J. T. and Haniffa, Muzlifah and Moffett, Ashley and Teichmann, Sarah A.},
