  author = {Becht, Etienne and Giraldo, Nicolas A. and Lacroix, Laetitia and Buttard, Bénédicte and Elarouci, Nabila and Petitprez, Florent and Selves, Janick and Laurent-Puig, Pierre and Sautès-Fridman, Catherine and Fridman, Wolf H. and de Reyniès, Aurélien},
