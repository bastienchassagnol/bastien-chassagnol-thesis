  keywords = {Dermatitis; Atopic,Humans,Image Processing; Computer-Assisted,Mass Spectrometry,Microscopy; Fluorescence,Pathology,Proteins,Proteomics,Psoriasis,Reproducibility of Results,Skin}
}

