  shorttitle = {Expression Deconvolution},
  author = {Lu, Peng and Nakorchevskiy, Aleksey and Marcotte, Edward M.},
  date = {2003-09-02},
  journaltitle = {Proceedings of the National Academy of Sciences},
  shortjournal = {PNAS},
  volume = {100},
  number = {18},
  eprint = {12934019},
  eprinttype = {pmid},
