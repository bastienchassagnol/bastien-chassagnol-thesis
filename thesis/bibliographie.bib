@article{quon_morris09,
  title = {{{ISOLATE}}: A Computational Strategy for Identifying the Primary Origin of Cancers Using High-Throughput Sequencing},
  shorttitle = {{{ISOLATE}}},
  author = {Quon, Gerald and Morris, Quaid},
  date = {2009-11-01},
  journaltitle = {Bioinformatics (Oxford, England)},
  shortjournal = {Bioinformatics},
